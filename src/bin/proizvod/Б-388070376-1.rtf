\u1072\'3f) \u1087\'3f\u1086\'3f\u1089\'3f\u1090\'3f\u1091\'3f\u1087\'3f\u1083\'3f\u1077\'3f\u1085\'3f\u1080\'3f\u1077\'3f \u1085\'3f\u1072\'3f \u1088\'3f\u1072\'3f\u1089\'3f\u1095\'3f\u1077\'3f\u1090\'3f\u1085\'3f\u1099\'3f\u1081\'3f \u1089\'3f\u1095\'3f\u1077\'3f\u1090\'3f \u1071\'3f\u1085\'3f\u1076\'3f\u1077\'3f\u1082\'3f\u1089\'3f\u1072\'3f \u1076\'3f\u1077\'3f\u1085\'3f\u1077\'3f\u1078\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1089\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1089\'3f\u1090\'3f\u1074\'3f \u1074\'3f \u1088\'3f\u1072\'3f\u1079\'3f\u1084\'3f\u1077\'3f\u1088\'3f\u1077\'3f, \u1091\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1072\'3f\u1085\'3f\u1085\'3f\u1086\'3f\u1084\'3f \u1074\'3f \u1085\'3f\u1072\'3f\u1089\'3f\u1090\'3f\u1086\'3f\u1103\'3f\u1097\'3f\u1077\'3f\u1084\'3f \u1057\'3f\u1095\'3f\u1077\'3f\u1090\'3f\u1077\'3f (100% \u1087\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1086\'3f\u1087\'3f\u1083\'3f\u1072\'3f\u1090\'3f\u1072\'3f). \u1059\'3f\u1089\'3f\u1083\'3f\u1091\'3f\u1075\'3f\u1080\'3f \u1086\'3f\u1082\'3f\u1072\'3f\u1079\'3f\u1099\'3f\u1074\'3f\u1072\'3f\u1102\'3f\u1090\'3f\u1089\'3f\u1103\'3f \u1074\'3f \u1086\'3f\u1073\'3f\u1097\'3f\u1077\'3f\u1084\'3f \u1086\'3f\u1073\'3f\u1098\'3f\u1077\'3f\u1084\'3f\u1077\'3f, \u1089\'3f\u1086\'3f\u1086\'3f\u1090\'3f\u1074\'3f\u1077\'3f\u1090\'3f\u1089\'3f\u1090\'3f\u1074\'3f\u1091\'3f\u1102\'3f\u1097\'3f\u1077\'3f\u1084\'3f \u1089\'3f\u1091\'3f\u1084\'3f\u1084\'3f\u1077\'3f \u1087\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1086\'3f\u1087\'3f\u1083\'3f\u1072\'3f\u1090\'3f\u1099\'3f, \u1079\'3f\u1072\'3f \u1080\'3f\u1089\'3f\u1082\'3f\u1083\'3f\u1102\'3f\u1095\'3f\u1077\'3f\u1085\'3f\u1080\'3f\u1077\'3f\u1084\'3f \u1089\'3f\u1083\'3f\u1091\'3f\u1095\'3f\u1072\'3f\u1077\'3f\u1074\'3f, \u1087\'3f\u1088\'3f\u1077\'3f\u1076\'3f\u1091\'3f\u1089\'3f\u1084\'3f\u1086\'3f\u1090\'3f\u1088\'3f\u1077\'3f\u1085\'3f\u1085\'3f\u1099\'3f\u1093\'3f \u1087\'3f. 4.1.;
\par 
}
